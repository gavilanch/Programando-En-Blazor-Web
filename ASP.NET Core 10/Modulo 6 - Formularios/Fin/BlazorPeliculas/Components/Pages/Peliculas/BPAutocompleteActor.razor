<div class="mb-3">
    <label>Actores:</label>
    <div>
        <MudAutocomplete T="Actor" Placeholder="Seleccione un actor..."
                         SearchFunc="Search" ToStringFunc="@(e=> null)"
                         Value="actorSeleccionado" ValueChanged="ValueChanged"
                        @ref="mudAutoComplete" >
            <ItemTemplate Context="actor">
                <img style="width: 50px" src="@actor.FotoURL" /> @actor.Nombre
            </ItemTemplate>
        </MudAutocomplete>

        <ul class="list-group">
            @foreach (var item in ActoresSeleccionados)
            {
                <li draggable="true" 
                    @ondragstart="@(() => HandleDragStart(item))"
                    @ondragover="@(() => HandleDragOver(item))"
                    class="list-group-item list-group-item-action">
                    @item.Nombre / <input type="text" placeholder="Personaje" @bind="item.Personaje" />

                    <span @onclick="@(() => ActoresSeleccionados.Remove(item))"
                          class="badge bg-primary rounded-pill" style="cursor:pointer">
                        X
                    </span>


                </li>
            }
        </ul>

    </div>
</div>

@code {

    [Parameter] public List<Actor> ActoresSeleccionados { get; set; } = [];
    Actor? actorSeleccionado;
    private MudAutocomplete<Actor>? mudAutoComplete;
    Actor? itemArrastrado;

    private async Task<IEnumerable<Actor>> Search(string value,
            CancellationToken cancellationToken)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return new List<Actor>();
        }

        var lista = new List<Actor>
        {
                new() { Id = 1, Nombre = "Tom Holland", FotoURL = "https://upload.wikimedia.org/wikipedia/commons/thumb/5/58/Tom_Holland_during_pro-am_Wentworth_golf_club_2023-2.jpg/500px-Tom_Holland_during_pro-am_Wentworth_golf_club_2023-2.jpg" },
                new() { Id = 2, Nombre = "Tom Hanks", FotoURL = "https://upload.wikimedia.org/wikipedia/commons/thumb/3/39/TomHanksPrincEdw031223_%2811_of_41%29_%28cropped%29.jpg/500px-TomHanksPrincEdw031223_%2811_of_41%29_%28cropped%29.jpg" },
                new() { Id = 3, Nombre = "Samuel L. Jackson", FotoURL = "https://upload.wikimedia.org/wikipedia/commons/thumb/2/29/SamuelLJackson.jpg/500px-SamuelLJackson.jpg" },
        };

        return lista.Where(x =>
                x.Nombre!.Contains(value, StringComparison.InvariantCultureIgnoreCase));

    }

    async Task ValueChanged(Actor actor)
    {

        if (actor is null)
        {
            return;
        }

        if (!ActoresSeleccionados.Any(x => x!.Equals(actor)))
        {
            ActoresSeleccionados.Add(actor);
        }

        actorSeleccionado = null;

        await mudAutoComplete!.ClearAsync();
    }

    private void HandleDragStart(Actor item)
    {
        itemArrastrado = item;
    }

    private void HandleDragOver(Actor item)
    {
        if (itemArrastrado is null)
        {
            return;
        }


        if (!item!.Equals(itemArrastrado))
        {
            var indiceElementoArrastrado = ActoresSeleccionados.IndexOf(itemArrastrado);
            var indiceElemento = ActoresSeleccionados.IndexOf(item);
            ActoresSeleccionados[indiceElemento] = itemArrastrado;
            ActoresSeleccionados[indiceElementoArrastrado] = item;

        }
    }
}
